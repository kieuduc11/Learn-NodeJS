<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <title>
    Thanh toán - LaptopShop
  </title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <meta content="" name="keywords">
  <meta content="" name="description">

  <!-- Google Web Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap" rel="stylesheet">

  <!-- Icon Font Stylesheet -->
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Libraries Stylesheet -->
  <link href="/client/lib/lightbox/css/lightbox.min.css" rel="stylesheet">
  <link href="/client/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">


  <!-- Customized Bootstrap Stylesheet -->
  <link href="/client/css/bootstrap.min.css" rel="stylesheet">

  <!-- Template Stylesheet -->
  <link href="/client/css/style.css" rel="stylesheet">
</head>

<body>

  <!-- Spinner -->
  <div id="spinner" class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50  d-flex align-items-center justify-content-center">
    <div class="spinner-grow text-primary" role="status"></div>
  </div>

  <!-- Navbar -->
  <%- include('../layout/header'); -%>
  <div class="py-5"></div>

  <div class="container py-5 mt-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thanh Toán Giỏ Hàng</li>
      </ol>
    </nav>

    <% const formatPrice=(price)=> new Intl.NumberFormat('vi-VN', {
        style: 'currency',
        currency: 'VND'
    }).format(price); %>

    <div class="card mb-4 shadow-sm">
      <div class="card-body p-0">
        <table class="table mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th scope="col">Sản phẩm</th>
              <th scope="col">Tên</th>
              <th scope="col">Giá cả</th>
              <th scope="col">Số lượng</th>
              <th scope="col">Thành tiền</th>
            </tr>
          </thead>
          <tbody>
            <% cartDetails.forEach( function (cartDetail) { %>
            <tr>
              <th scope="row">
                <div class="d-flex align-items-center">
                  <img src="/images/products/<%=cartDetail.product.image %>" style="width:70px; height:70px; object-fit:cover;" class="rounded">
                </div>
              </th>
              <td>
                <p class="mb-0 mt-4">
                  <a target="_blank" href="/product/<%=cartDetail.product.id %>">
                    <%=cartDetail.product.name %>
                  </a>
                </p>
              </td>
              <td>
                <p class="mb-0 mt-4">
                  <%= formatPrice(cartDetail.product.price) %>
                </p>
              </td>
              <td>
                <div class="input-group quantity mt-4" style="width: 100px;">
                  <input type="text" class="form-control form-control-sm text-center border-0" value="<%=cartDetail.quantity %>" disabled />
                </div>
              </td>
              <td>
                <p class="mb-0 mt-4" data-cart-detail-id="<%=cartDetail.id %>">
                  <%= formatPrice(cartDetail.quantity * cartDetail.price) %>
                </p>
              </td>

            </tr>
            <% }) %>
            <%if (user?.sumCart===0) { %>
            <tr>
              <td colspan="6"> Chưa có sản phẩm trong giỏ hàng</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div class="card-footer d-flex justify-content-end">
        <strong>
            Tổng tiền: <%= formatPrice(totalPrice) %>
        </strong>
      </div>
    </div>

    <%if (user?.sumCart> 0) { %>
    <form action="/place-order" method="post">
      <input style="display: none;" name="totalPrice" value="<%= totalPrice%>">
      <div class="mt-5 row g-4 justify-content-start align-items-stretch">

        <!-- LEFT -->
        <div class="col-12 col-md-6 d-flex">
          <div class="card shadow-sm border-0 rounded-4 w-100">
            <div class="card-body p-4 d-flex flex-column">

              <h5 class="mb-4 fw-bold">
                <i class="fas fa-user-circle me-2 text-primary"></i>
                Thông Tin Người Nhận
              </h5>

              <div class="form-group mb-3">
                <label class="form-label fw-semibold">Tên người nhận:</label>
                <input class="form-control rounded px-3" name="receiverName" placeholder="Nhập tên người nhận" required />
              </div>

              <div class="form-group mb-3">
                <label class="form-label fw-semibold">Địa chỉ nhận hàng:</label>
                <input class="form-control rounded px-3" name="receiverAddress" placeholder="Nhập địa chỉ chi tiết" required />
              </div>

              <div class="form-group mb-3">
                <label class="form-label fw-semibold">Số điện thoại:</label>
                <input class="form-control rounded px-3" name="receiverPhone" placeholder="Nhập số điện thoại" required />
              </div>

              <div class="d-flex align-items-center mt-auto pt-3">
                <i class="fas fa-arrow-left me-2"></i>
                <a href="/cart" class="text-decoration-none">
                  Quay lại giỏ hàng
                </a>
              </div>

            </div>
          </div>
        </div>

        <!-- RIGHT -->
        <div class="col-12 col-md-6 d-flex">
          <div class="bg-light rounded w-100 d-flex flex-column">

            <div class="p-4">
              <h1 class="display-6 mb-4">
                Thông Tin <span class="fw-normal">Thanh Toán</span>
              </h1>

              <div class="d-flex justify-content-between">
                <h5 class="mb-0 me-4">Phí vận chuyển</h5>
                <p class="mb-0">0 đ</p>
              </div>

              <div class="mt-3 d-flex justify-content-between">
                <h5 class="mb-0 me-4">Hình thức</h5>
                <p class="mb-0">Thanh toán khi nhận hàng (COD)</p>
              </div>
            </div>

            <div class="py-4 mb-4 border-top border-bottom d-flex justify-content-between">
              <h5 class="mb-0 ps-4 me-4">Tổng số tiền</h5>
              <p class="mb-0 pe-4" data-cart-total-price="<%= totalPrice %>">
                <%= formatPrice(totalPrice) %>
              </p>
            </div>

            <button class="btn border-secondary rounded-pill px-4 py-3 text-primary text-uppercase mb-4 ms-4 mx-auto">
              Xác nhận thanh toán
            </button>
          </div>
        </div>

      </div>
    </form>
    <% } %>
  </div>

  <!-- Footer Start -->
  <%- include('../layout/footer'); -%>
  <!-- Footer End -->

  <!-- Back to Top -->
  <a href="#" class="btn btn-primary border-3 border-primary rounded-circle back-to-top"><i class="fa fa-arrow-up"></i></a>


  <!-- JavaScript Libraries -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/client/lib/easing/easing.min.js"></script>
  <script src="/client/lib/waypoints/waypoints.min.js"></script>
  <script src="/client/lib/lightbox/js/lightbox.min.js"></script>
  <script src="/client/lib/owlcarousel/owl.carousel.min.js"></script>

  <!-- Template Javascript -->
  <script src="/client/js/main.js"></script>
</body>

</html>